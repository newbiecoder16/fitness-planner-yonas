<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/bg_elevated" />
            <stroke android:width="1.5dp" android:color="@color/border_active" />
            <corners android:radius="@dimen/radius_button" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/bg_card" />
            <stroke android:width="1.5dp" android:color="@color/border_default" />
            <corners android:radius="@dimen/radius_button" />
        </shape>
    </item>
</selector>
