<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:orientation="vertical">

    <!-- Top accent bar -->
    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/top_bar_height"
        android:background="@color/orange_primary" />

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/screen_padding_h"
        android:layout_marginTop="@dimen/space_md">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textSize="22sp"
            android:textColor="@color/text_primary"
            android:padding="@dimen/space_sm" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/workout_planner_title"
            style="@style/Text.Hero"
            android:layout_marginStart="@dimen/space_sm" />

        <TextView
            android:id="@+id/btnCreateWorkout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/create_workout"
            style="@style/Text.OrangeLink" />
    </LinearLayout>

    <!-- Workout list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvWorkoutSessions"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="@dimen/screen_padding_h"
        android:clipToPadding="false"
        android:overScrollMode="never" />

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/layoutEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        android:padding="@dimen/space_xl">
        <TextView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:gravity="center"
            android:text="📋"
            android:textSize="40sp"
            android:background="@drawable/bg_logo_tile" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/no_workouts_yet"
            android:textSize="15sp"
            android:textColor="@color/text_muted"
            android:gravity="center"
            android:layout_marginTop="@dimen/space_lg"
            android:lineSpacingExtra="4dp" />
    </LinearLayout>

</LinearLayout>
